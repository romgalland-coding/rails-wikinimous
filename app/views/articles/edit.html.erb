<div class="container my-4" style="max-width: 800px;">
  <h1 class="mb-4">Edit article</h1>

  <%= render "articles/form", article: @article %>

  <div class="mt-3">
    <%= link_to "Show", article_path(@article), class: "text-decoration-none" %>
    <span class="text-muted mx-2">|</span>
    <%= link_to "Back", articles_path, class: "text-decoration-none" %>
  </div>
</div>
