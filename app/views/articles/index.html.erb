<div class="container" style="max-width: 800px;">
  
  <% @articles.each do |article| %>
    <div class="mb-4">
      <h2 class="mb-2">
        <%= link_to article.title, article_path(article), class: "text-decoration-none" %>
      </h2>
      <p class="text-muted"><%= article.content.truncate(80) %></p>
    </div>
  <% end %>
</div>
